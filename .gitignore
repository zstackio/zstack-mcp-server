# ==========================
# Python 核心忽略项
# ==========================
# 字节码编译文件 (Python 自动生成的缓存)
__pycache__/
*.py[cod]
*$py.class

# C 扩展编译文件
*.so

# ==========================
# 包分发与构建 (Distribution / Packaging)
# ==========================
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==========================
# 虚拟环境 (Virtual Environments)
# ==========================
# 常见的虚拟环境目录名
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# ==========================
# 单元测试与代码覆盖率 (Unit Test / Coverage)
# ==========================
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# ==========================
# IDE 与 编辑器配置 (IDE / Editor)
# ==========================
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# PyCharm / IntelliJ IDEA
.idea/

# Jupyter Notebook
.ipynb_checkpoints

# ==========================
# 环境变量与敏感信息 (Environment Variables)
# ==========================
# 极其重要！防止 API Key 或数据库密码泄露
.env
.env.local
.env.*
config/zstack.env
opencode.json
articles/

# ==========================
# 常用框架特定文件
# ==========================
# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/

# Flask
instance/
.webassets-cache

# Scrapy
.scrapy

# ==========================
# 操作系统生成文件 (OS Generated)
# ==========================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

